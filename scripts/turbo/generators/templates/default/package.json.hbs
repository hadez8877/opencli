{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@opencli/{{name}}",
  "version": "0.1.0",
  "description": "{{description}}",
  "scripts": {
    "build": "tsc --noEmit && tsup",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "directories": {
    "lib": "src",
    "test": "__tests__"
  },
  "files": [
    "dist"
  ],
  "contributors": [
    "Fabricio Pasapera Viera (@Hadez)"
  ],
  "license": "Apache-2.0",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/hadez8877/opencli.git",
    "directory": "packages/{{name}}"
  },
  "bugs": {
    "url": "https://github.com/hadez8877/opencli/issues"
  },
  "funding": "https://github.com/hadez8877/opencli?sponsor",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-neon": "^0.4.0",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-formatter-pretty": "^7.1.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.12",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
