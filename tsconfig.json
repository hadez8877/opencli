// This file is the workspace solution: it references each package's
// tsconfig.json so a single `tsc -b` covers the whole monorepo.
{
  "extends": "./configs/tsconfig.base.json",
  "files": [
    // Root config files that aren't in any package
    "./prettier.config.mjs",
    "./eslint.config.js",
    "./vitest.config.js"
  ],
  "references": [{ "path": "./packages/opencli/tsconfig.json" }]
}
