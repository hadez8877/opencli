{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencli",
  "version": "0.0.0",
  "description": "OpenCLI is a library for building Command Line Interfaces (CLIs)",
  "scripts": {
    "build": "opencli-scripts build \"src/**/*.{ts,js}\" --copy-wasm && tsc -b ",
    "test": "vitest run --config ../../vitest.config.js",
    "lint": "biome lint . && eslint --cache --concurrency=auto ."
  },
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "directories": {
    "lib": "src",
    "test": "__tests__"
  },
  "files": [
    "dist"
  ],
  "//a": "MOST PACKAGES SHOULD GO IN DEV_DEPENDENCIES! THEY WILL BE BUNDLED.",
  "//b": "DEPENDENCIES IS FOR UNBUNDLED PACKAGES",
  "contributors": [
    "Fabricio Pasapera Viera (@Hadez)"
  ],
  "license": "MIT",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/hadez8877/opencli.git",
    "directory": "packages/opencli"
  },
  "bugs": {
    "url": "https://github.com/hadez8877/opencli/issues"
  },
  "funding": "https://github.com/hadez8877/opencli?sponsor",
  "dependencies": {},
  "devDependencies": {
    "opencli-scripts": "workspace:*",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.4.1",
    "eslint-config-neon": "^0.5.2",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-formatter-pretty": "^7.1.0",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
