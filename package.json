{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "root",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "release": "pnpm run build && changeset publish",
    "build": "turbo run build --concurrency=4",
    "build:ci": "turbo run build:ci --concurrency=4",
    "build:affected": "turbo run build --filter=...[origin/main] --concurrency=4",
    "build:examples": "turbo run build --filter=\"@example/*\"",
    "test": "turbo run test --concurrency=4",
    "test:affected": "turbo run test --filter=...[origin/main] --concurrency=4",
    "typecheck": "tsc -b",
    "lint": "turbo run lint --concurrency=4",
    "lint:affected": "turbo run lint --filter=...[origin/main] --concurrency=4",
    "format": "pnpm run format:code && pnpm run format:imports",
    "format:code": "biome format --write && prettier -w \"**/*\" --ignore-unknown --cache",
    "format:imports": "biome check --formatter-enabled=false --write",
    "prepare": "is-ci || husky",
    "update": "pnpm --recursive update --interactive",
    "update:latest": "pnpm --recursive update --interactive --latest",
    "version": "changeset version && node ./scripts/deps/update-example-versions.mjs && pnpm install --no-frozen-lockfile && pnpm run format",
    "preinstall": "npx only-allow pnpm"
  },
  "workspaces": [
    "packages/*",
    "scripts"
  ],
  "author": "Fabricio Pasapera Viera (@Hadez)",
  "keywords": [
    "opencli",
    "cli",
    "command-line-interface",
    "terminal",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hadez8877/opencli.git"
  },
  "bugs": {
    "url": "https://github.com/hadez8877/opencli/issues"
  },
  "funding": "https://github.com/hadez8877/opencli?sponsor",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-angular": "^21.0.2",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^25.6.2",
    "esbuild": "0.27.3",
    "eslint": "^10.4.0",
    "eslint-config-neon": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lodash.merge": "^4.6.2",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "tinyglobby": "^0.2.16",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.1"
}
