{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "**/*",
        "!__tests__/**/*",
        "!__mocks__/**/*",
        "!.cache/**/*",
        "!.turbo/**/*",
        "!mod.js",
        "!mod.js.map"
      ],
      "outputs": ["dist/**", "mod.js", "mod.js.map"],
      "outputLogs": "errors-only"
    },
    "build:ci": {
      "dependsOn": ["^build:ci"],
      "inputs": [
        "**/*",
        "!__tests__/**/*",
        "!__mocks__/**/*",
        "!.cache/**/*",
        "!.turbo/**/*",
        "!mod.js",
        "!mod.js.map"
      ],
      "outputs": ["dist/**", "mod.js", "mod.js.map"],
      "outputLogs": "errors-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "**/*",
        "../../vitest.config.ts",
        "__mocks__/**",
        "__tests__/**",
        "vitest.config.ts"
      ],
      "outputs": ["coverage/**"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["**/*", "../../biome.json", "../../eslint.config.js", "../../prettier.config.mjs"],
      "outputs": [],
      "outputLogs": "errors-only"
    }
  }
}
